# Frontend Environment Variables — Production (Vercel)

# API endpoint (production backend on Vercel)
REACT_APP_API_URL=https://api.cornerstoneevents.in

# Production flag
REACT_APP_ENV=production
# Frontend Environment Variables — Local Development

# API endpoint (local backend)
REACT_APP_API_URL=http://localhost:5003

# Optional: Analytics, sentry, etc.
REACT_APP_ENV=development